server.port=8080

# Database configurations (Change credentials as needed)
spring.datasource.url=jdbc:mysql://localhost:3306/anydraw?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=YOUR_DATABASE_USERNAME
spring.datasource.password=YOUR_DATABASE_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA and Hibernate properties
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

# JWT Configurations (Change secret for production)
jwt.secret=YOUR_JWT_SECRET_KEY
jwt.expiration=86400000
